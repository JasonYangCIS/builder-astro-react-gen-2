---
import { fetchEntries, fetchOneEntry } from "@builder.io/sdk-react";
import Layout from "../layouts/Layout.astro";
import { BuilderPage } from "../components/BuilderPage/BuilderPage";

export async function getStaticPaths() {
  const entries = await fetchEntries({
    apiKey: import.meta.env.PUBLIC_BUILDER_API_KEY,
    model: "page",
    options: {
      fields: "data.url",
    },
  });

  const formattedPaths = entries.map((entry) => {
    const url = entry.data?.url ?? "/";
    const stripped = url.replace(/^\//, "");
    return {
      params: { path: stripped || undefined },
    };
  });

  return formattedPaths;
}

const { path } = Astro.params;
// Builder expects urlPath like location.pathname (leading slash). Params omit it for routing.
const urlPath = path ? `/${path.replace(/^\//, "")}` : "/";

const builderContent = await fetchOneEntry({
  apiKey: import.meta.env.PUBLIC_BUILDER_API_KEY,
  model: "page",
  userAttributes: { urlPath },
});

const apiKey = import.meta.env.PUBLIC_BUILDER_API_KEY;
---

<Layout>
  <BuilderPage
    client:load
    content={builderContent}
    model="page"
    apiKey={apiKey}
  />
</Layout>
