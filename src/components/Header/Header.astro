---
import { fetchEntries } from "@builder.io/sdk-react";
import { NavItems } from "./NavItems";
import type { NavEntry } from "./NavItems";

const rawEntries = await fetchEntries({
  apiKey: import.meta.env.PUBLIC_BUILDER_API_KEY,
  model: "header-nav-menu",
  options: {
    fields: "id,data",
    limit: 5,
  },
}).catch(() => []);

const navEntries: NavEntry[] = rawEntries
  .filter((e) => e.data?.text && e.data?.url)
  .map((e) => ({
    id: e.id ?? crypto.randomUUID(),
    text: e.data!.text as string,
    url: e.data!.url as string,
  }));
---

<header class="site-header">
  <div class="header-inner">
    <!-- Logo / site name -->
    <a href="/" class="site-logo" aria-label="Go to homepage">
      <svg
        width="28"
        height="28"
        viewBox="0 0 28 28"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
      >
        <rect width="28" height="28" rx="6" fill="currentColor" opacity="0.15" />
        <path
          d="M8 20V8h5.5c1.4 0 2.5.3 3.3 1 .8.6 1.2 1.5 1.2 2.6 0 .7-.2 1.4-.6 1.9-.4.5-.9.9-1.5 1.1.8.2 1.4.6 1.9 1.2.5.6.7 1.3.7 2.1 0 1.2-.4 2.1-1.3 2.8-.9.7-2 1-3.5 1H8Zm2.5-7.2h2.8c.8 0 1.4-.2 1.8-.5.4-.3.6-.8.6-1.4s-.2-1-.6-1.4c-.4-.3-1-.5-1.8-.5h-2.8v3.8Zm0 5h3.1c.8 0 1.5-.2 1.9-.5.4-.4.7-.9.7-1.5s-.2-1.2-.7-1.5c-.4-.4-1.1-.5-1.9-.5h-3.1V17.8Z"
          fill="currentColor"
        />
      </svg>
      <span class="site-name">Jason Yang - Builder.io - Astro</span>
    </a>

    <!-- Nav items (desktop + mobile hamburger) -->
    <NavItems client:load entries={navEntries} />
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    width: 100%;
    border-bottom: 1px solid var(--border);
    background-color: var(--background);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 64px;
  }

  .site-logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--foreground);
    text-decoration: none;
    font-weight: 700;
    font-size: 1.125rem;
    transition: opacity 0.15s;
  }

  .site-logo:hover {
    opacity: 0.8;
  }

  .site-name {
    line-height: 1;
  }

  /* ── Styles consumed by NavItems React component ── */

  :global(.nav-link) {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--muted-foreground);
    text-decoration: none;
    transition: color 0.15s;
  }

  :global(.nav-link:hover) {
    color: var(--foreground);
  }

  :global(.hamburger-btn) {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 6px;
    border: 1px solid var(--border);
    background: var(--card);
    color: var(--foreground);
    cursor: pointer;
    transition: background-color 0.15s;
  }

  :global(.hamburger-btn:hover) {
    background-color: var(--accent);
    color: var(--accent-foreground);
  }

  :global(.mobile-backdrop) {
    position: fixed;
    inset: 0;
    background: oklch(0 0 0 / 40%);
    z-index: 40;
  }

  :global(.mobile-drawer) {
    position: fixed;
    top: 64px;
    right: 0;
    bottom: 0;
    width: min(280px, 85vw);
    background-color: var(--card);
    border-left: 1px solid var(--border);
    z-index: 50;
    overflow-y: auto;
    transform: translateX(100%);
    transition: transform 0.25s ease;
  }

  :global(.mobile-drawer--open) {
    transform: translateX(0);
  }

  :global(.mobile-nav-list) {
    list-style: none;
    margin: 0;
    padding: 1rem 0;
  }

  :global(.mobile-nav-link) {
    display: block;
    padding: 0.75rem 1.5rem;
    font-size: 1rem;
    font-weight: 500;
    color: var(--foreground);
    text-decoration: none;
    transition: background-color 0.15s;
  }

  :global(.mobile-nav-link:hover) {
    background-color: var(--accent);
    color: var(--accent-foreground);
  }

  :global(.mobile-nav-empty) {
    padding: 0.75rem 1.5rem;
    font-size: 0.875rem;
    color: var(--muted-foreground);
  }
</style>
